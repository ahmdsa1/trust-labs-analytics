# Streamlit Cloud Secrets Template
# Copy this to secrets.toml and fill in your values
# DO NOT commit secrets.toml to Git — it is in .gitignore

[auth]
# Optional: Override default users with environment-based credentials
# admin_password = "your-secure-admin-password"
# viewer_password = "your-secure-viewer-password"

[database]
# Optional: External database connection (SQLite is default)
# connection_string = "sqlite:///trust_labs.db"

[email]
# For automated report email delivery (future feature)
# smtp_server = "smtp.gmail.com"
# smtp_port = 587
# smtp_username = "your-email@gmail.com"
# smtp_password = "your-app-password"
